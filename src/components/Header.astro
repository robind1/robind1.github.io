---
const links = [
  { label: 'Work', href: '/#work' },
  { label: 'About', href: '/about' },
];
---

<header
  class="sticky top-0 z-50 border-b border-line bg-paper/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4 sm:px-8"
  >
    <a
      href="/"
      class="text-[15px] font-semibold tracking-tight text-ink transition-opacity hover:opacity-60"
    >
      Robin Dosan
    </a>
    <ul class="flex items-center gap-7">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-[14px] text-muted transition-colors hover:text-ink"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href="https://github.com/robind1"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[14px] text-muted transition-colors hover:text-ink"
        >
          GitHub
        </a>
      </li>
    </ul>
  </nav>
</header>
