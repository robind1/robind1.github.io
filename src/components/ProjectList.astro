---
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<section id="work" class="mx-auto max-w-5xl px-6 py-16 sm:px-8 sm:py-24">
  <div class="flex items-baseline justify-between">
    <span class="text-[18px] text-faint">
      {String(projects.length).padStart(2, '0')} projects
    </span>
  </div>

  <ul class="mt-4 border-t border-line">
    {
      projects.map((project, i) => (
        <li>
          <a
            href={`/projects/${project.id}`}
            class="group grid grid-cols-[auto_1fr] items-start gap-x-5 gap-y-3 border-b border-line py-8 transition-colors hover:bg-wash sm:grid-cols-[3rem_1fr_auto] sm:gap-x-8 sm:px-3"
          >
            <span class="pt-1 font-mono text-[14px] text-faint">
              {String(i + 1).padStart(2, '0')}
            </span>

            <div class="min-w-0">
              <h3 class="text-xl font-semibold tracking-tight text-ink transition-opacity sm:text-2xl">
                {project.data.title}
              </h3>
              <p class="mt-2 max-w-xl text-[16px] leading-relaxed text-muted">
                {project.data.excerpt}
              </p>
              <ul class="mt-4 flex flex-wrap gap-2">
                {project.data.tags.map((tag) => (
                  <li class="rounded-full border border-line px-2.5 py-0.5 text-[12px] text-muted">
                    {tag}
                  </li>
                ))}
              </ul>
            </div>

            <div class="col-span-2 sm:col-span-1 sm:self-center">
              <img
                src={project.data.teaser}
                alt=""
                loading="lazy"
                class="h-28 w-full rounded-lg border border-line object-cover transition-transform duration-300 group-hover:scale-[1.02] sm:h-40 sm:w-46"
              />
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</section>
